{
  "name": "@glyph/desktop",
  "version": "0.6.0",
  "private": false,
  "description": "Glyph - A minimal markdown viewer and editor for macOS and Windows. Browse local notes, edit markdown fast, and read rendered documents in a focused desktop workspace.",
  "keywords": [
    "desktop",
    "editor",
    "electron",
    "markdown",
    "minimal",
    "notes",
    "productivity"
  ],
  "license": "MIT",
  "author": "Falak Gala",
  "repository": {
    "type": "git",
    "url": "https://github.com/FALAK097/glyph.git"
  },
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p electron/tsconfig.json --watch\" \"wait-on http-get://127.0.0.1:5173 dist-electron/electron/main.js && node scripts/launch-dev-electron.mjs\"",
    "build": "tsc -p electron/tsconfig.json && vite build",
    "verify:runtime-deps": "node scripts/check-runtime-dependencies.mjs",
    "dist": "pnpm run build && pnpm run verify:runtime-deps && electron-builder --publish never",
    "release": "pnpm run build && pnpm run verify:runtime-deps && electron-builder --publish always",
    "test:e2e": "pnpm run build && playwright test -c playwright.config.ts",
    "test:e2e:headed": "pnpm run build && playwright test -c playwright.config.ts --headed",
    "test:e2e:debug": "pnpm run build && playwright test -c playwright.config.ts --debug",
    "test:e2e:run": "playwright test -c playwright.config.ts",
    "test:e2e:run:headed": "playwright test -c playwright.config.ts --headed",
    "test:e2e:ui": "pnpm run build && playwright test -c playwright.config.ts --ui",
    "test:e2e:report": "playwright show-report playwright-report",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p electron/tsconfig.json",
    "lint": "oxlint . --ignore-pattern 'dist/**' --ignore-pattern 'dist-electron/**' --ignore-pattern 'release/**' --ignore-pattern 'playwright-report/**' --ignore-pattern 'test-results/**'",
    "fmt": "oxfmt . '!dist/**' '!dist-electron/**' '!release/**' '!playwright-report/**' '!test-results/**'",
    "fmt:check": "oxfmt . '!dist/**' '!dist-electron/**' '!release/**' '!playwright-report/**' '!test-results/**' --check"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "electron-updater": "^6.6.2",
    "marked": "^17.0.4",
    "pdfkit": "^0.17.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@tailwindcss/vite": "^4.2.1",
    "@tiptap/core": "^3.20.1",
    "@tiptap/extension-code-block-lowlight": "^3.20.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-table": "^3.20.1",
    "@tiptap/extension-table-cell": "^3.20.1",
    "@tiptap/extension-table-header": "^3.20.1",
    "@tiptap/extension-table-row": "^3.20.1",
    "@tiptap/extension-task-item": "^3.20.1",
    "@tiptap/extension-task-list": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@tiptap/suggestion": "^3.20.1",
    "@types/node": "^22.13.10",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19.0.11",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "agentation": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "highlight.js": "^11.11.1",
    "knip": "^6.3.0",
    "lowlight": "^3.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-grab": "^0.1.32",
    "rollup-plugin-visualizer": "^7.0.1",
    "shadcn": "^4.0.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.9.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3",
    "zustand": "^5.0.3"
  },
  "build": {
    "appId": "com.falakgala.glyph",
    "productName": "Glyph",
    "artifactName": "Glyph-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/electron/main.js"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "Glyph-mac.${ext}"
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Glyph-windows.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "FALAK097",
        "repo": "glyph",
        "releaseType": "release"
      }
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor"
      },
      {
        "ext": "mdx",
        "name": "MDX Document",
        "description": "MDX document",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown File",
        "description": "Markdown file",
        "role": "Editor"
      }
    ]
  },
  "productName": "Glyph"
}
